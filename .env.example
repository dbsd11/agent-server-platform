# Database Configuration
DB_ENGINE=sqlite
DB_NAME=agent_server.db
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=1
DB_TIMEOUT=30

# Server Configuration
GRADIO_PORT=8080
FLASK_PORT=5000
GRADIO_HOST=0.0.0.0
FLASK_HOST=0.0.0.0

# Authentication
AUTH_ENABLED=true

# Watchdog Configuration
WATCHDOG_CHECK_INTERVAL=10
WATCHDOG_DEFAULT_TIMEOUT=3600

# Sandbox Configuration
SANDBOX_TIMEOUT=300
SANDBOX_MAX_OUTPUT_SIZE=1048576

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(filename)s:%(lineno)d - %(levelname)s - %(message)s

# Admin Credentials (emergency backdoor login; leave blank to disable)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# LLM Configuration (DashScope / OpenAI-compatible)
DASHSCOPE_API_KEY=your-dashscope-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_MAX_TOKENS=4096
LLM_ENABLE_THINKING=true
LLM_TIMEOUT=120
